{
  "name": "@alphacifer/core-utils",
  "version": "0.0.9",
  "description": "Core Utils for Alpha's projects.",
  "main": "./lib/index.cjs",
  "module": "./lib/index.mjs",
  "types": "./lib/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./lib/index.d.mts",
        "default": "./lib/index.mjs"
      },
      "require": {
        "types": "./lib/index.d.cts",
        "default": "./lib/index.cjs"
      }
    },
    "./arrayUtils": {
      "import": {
        "types": "./lib/arrayUtils.d.mts",
        "default": "./lib/arrayUtils.mjs"
      },
      "require": {
        "types": "./lib/arrayUtils.d.cts",
        "default": "./lib/arrayUtils.cjs"
      }
    },
    "./dateUtils": {
      "import": {
        "types": "./lib/dateUtils.d.mts",
        "default": "./lib/dateUtils.mjs"
      },
      "require": {
        "types": "./lib/dateUtils.d.cts",
        "default": "./lib/dateUtils.cjs"
      }
    },
    "./objectUtils": {
      "import": {
        "types": "./lib/objectUtils.d.mts",
        "default": "./lib/objectUtils.mjs"
      },
      "require": {
        "types": "./lib/objectUtils.d.cts",
        "default": "./lib/objectUtils.cjs"
      }
    },
    "./remeda": {
      "import": {
        "types": "./lib/remeda.d.mts",
        "default": "./lib/remeda.mjs"
      },
      "require": {
        "types": "./lib/remeda.d.cts",
        "default": "./lib/remeda.cjs"
      }
    },
    "./slugify": {
      "import": {
        "types": "./lib/slugify.d.mts",
        "default": "./lib/slugify.mjs"
      },
      "require": {
        "types": "./lib/slugify.d.cts",
        "default": "./lib/slugify.cjs"
      }
    },
    "./stringUtils": {
      "import": {
        "types": "./lib/stringUtils.d.mts",
        "default": "./lib/stringUtils.mjs"
      },
      "require": {
        "types": "./lib/stringUtils.d.cts",
        "default": "./lib/stringUtils.cjs"
      }
    },
    "./uniqid": {
      "import": {
        "types": "./lib/uniqid.d.mts",
        "default": "./lib/uniqid.mjs"
      },
      "require": {
        "types": "./lib/uniqid.d.cts",
        "default": "./lib/uniqid.cjs"
      }
    },
    "./urlUtils": {
      "import": {
        "types": "./lib/urlUtils.d.mts",
        "default": "./lib/urlUtils.mjs"
      },
      "require": {
        "types": "./lib/urlUtils.d.cts",
        "default": "./lib/urlUtils.cjs"
      }
    }
  },
  "keywords": [
    "alpha",
    "dx",
    "core-utils"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "author": "Alpha",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zgid123/alpha-dx.git"
  },
  "license": "MIT",
  "scripts": {
    "prepublish": "pnpm build",
    "build": "tsdown"
  },
  "dependencies": {
    "date-fns": "4.1.0",
    "remeda": "2.34.0",
    "slugify": "1.6.9",
    "uniqid": "5.4.0"
  },
  "devDependencies": {
    "@types/uniqid": "5.3.4"
  }
}
