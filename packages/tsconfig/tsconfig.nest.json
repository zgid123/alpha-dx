{
  "extends": "./tsconfig.cmj.json",
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "Node16",
    "paths": {
      "~/*": [
        "${configDir}/src/*"
      ],
      "#/*": [
        "${configDir}/src/*"
      ]
    },
    "strictNullChecks": false,
    "strictPropertyInitialization": false
  }
}
