{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "outDir": "dist",
    "paths": {
      "~/*": [
        "${configDir}/src/*"
      ],
      "#/*": [
        "${configDir}/src/*"
      ]
    },
    "verbatimModuleSyntax": true
  },
  "exclude": [
    "**/node_modules/*"
  ]
}
