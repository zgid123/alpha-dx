{
  "name": "alpha-dx",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "preinstall": "npx only-allow pnpm",
    "clear": "pnpm -r exec rimraf node_modules dist .turbo lib && pnpm rimraf node_modules .turbo",
    "test": "vitest run --coverage",
    "update-packages": "pnpm update -i -r --latest",
    "build": "turbo run build",
    "release": "pnpm build && changeset version && pnpm publish -r",
    "set-release": "changeset"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.1.2",
      "onFail": "download"
    }
  },
  "packageManager": "pnpm@11.1.2",
  "devDependencies": {
    "@alphacifer/biome": "workspace:^",
    "@alphacifer/tsconfig": "workspace:^",
    "@biomejs/biome": "2.4.13",
    "@changesets/changelog-github": "0.6.0",
    "@changesets/cli": "2.31.0",
    "@vitest/coverage-istanbul": "4.1.5",
    "changeset": "0.2.6",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "rimraf": "6.1.3",
    "tsdown": "0.21.10",
    "turbo": "2.9.14",
    "vitest": "4.1.5"
  }
}
